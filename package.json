{
  "name": "n8n-nodes-secux",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for SecuX hardware wallet integration providing 26 resources and 150+ operations for multi-chain cryptocurrency management, transaction signing, NFT handling, and device management.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-secux.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-secux#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-secux/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "secux",
    "hardware-wallet",
    "cryptocurrency",
    "bitcoin",
    "ethereum",
    "blockchain",
    "multi-chain",
    "transaction-signing",
    "nft",
    "web3",
    "defi",
    "cold-storage",
    "usb-hid",
    "bluetooth"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SecuXDevice.credentials.js",
      "dist/credentials/SecuXess.credentials.js",
      "dist/credentials/SecuXNetwork.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SecuX/SecuX.node.js",
      "dist/nodes/SecuX/SecuXTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist/",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bitcoinjs-lib": "^6.1.5",
    "ecpair": "^2.1.0",
    "ethers": "^6.11.1",
    "@solana/web3.js": "^1.91.1",
    "xrpl": "^3.0.0",
    "@cosmjs/stargate": "^0.32.2",
    "node-hid": "^3.0.0",
    "@noble/hashes": "^1.3.3",
    "bip32": "^4.0.0",
    "bip39": "^3.1.0",
    "tiny-secp256k1": "^2.2.3",
    "bs58": "^5.0.0",
    "buffer": "^6.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@types/node-hid": "^1.3.4",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.30.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.2"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "files": [
    "dist/**/*"
  ]
}
